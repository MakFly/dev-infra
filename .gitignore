# Environment
.env
.env.local
.env.*.local

# OS
.DS_Store
.DS_Store?
._*
Thumbs.db

# IDE / Editors
.idea/
.vscode/
*.swp
*.swo
*~

# Logs & temporary
*.log
*.tmp
*.cache

# Package managers
node_modules/

# Docker generated files (never push content)
/docker/*
!/docker/.gitkeep

# Local overrides (never push content)
/overrides/*
!/overrides/.gitkeep

# Local project registry (never push project paths/ports)
/data/projects/*.env
!/data/projects/.gitkeep

# Scripts (private - never push)
/scripts/
