#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" && pwd)"
    source="$(readlink "$source")"
    [[ "$source" != /* ]] && source="$dir/$source"
  done
  cd -P "$(dirname "$source")" && pwd
}

SCRIPT_DIR="$(resolve_script_path)"
DEVHUB_DIR_DEFAULT="$(cd "$SCRIPT_DIR/.." && pwd)"
DEVHUB_DIR="${DEVHUB_DIR:-$DEVHUB_DIR_DEFAULT}"
COMPOSE_FILE="$DEVHUB_DIR/compose.yml"
ENV_FILE="$DEVHUB_DIR/.env"
VERSION_FILE="$DEVHUB_DIR/VERSION"
SCRIPTS_DIR="$DEVHUB_DIR/data/scripts"
PROJECT_SCRIPT="$SCRIPTS_DIR/project-init.sh"
WT_ADD_SCRIPT="$SCRIPTS_DIR/wt-add.sh"
WT_LIST_SCRIPT="$SCRIPTS_DIR/wt-list.sh"
WT_RM_SCRIPT="$SCRIPTS_DIR/wt-rm.sh"
WT_STATUS_SCRIPT="$SCRIPTS_DIR/wt-status.sh"
NETWORK_NAME="${DEVHUB_NETWORK:-dev-shared-net}"
DEFAULT_PROFILES=(core)
ALL_PROFILES="core,async,node"
STARTABLE_PROFILES="$ALL_PROFILES"
POSTGRES_CONTAINER="${POSTGRES_CONTAINER:-infra-postgres}"

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    echo "Missing required command: $1" >&2
    exit 1
  }
}

ensure_files() {
  [ -f "$COMPOSE_FILE" ] || { echo "Compose file not found: $COMPOSE_FILE" >&2; exit 1; }
  if [ ! -f "$ENV_FILE" ] && [ -f "$DEVHUB_DIR/.env.example" ]; then
    cp "$DEVHUB_DIR/.env.example" "$ENV_FILE"
    echo "Created $ENV_FILE from .env.example"
  fi
  [ -f "$ENV_FILE" ] || { echo "Env file not found: $ENV_FILE" >&2; exit 1; }
}

dc() {
  docker compose --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

ensure_network() {
  if ! docker network inspect "$NETWORK_NAME" >/dev/null 2>&1; then
    docker network create "$NETWORK_NAME" >/dev/null
    echo "Network created: $NETWORK_NAME"
  fi
}

join_profiles() {
  local IFS=,
  echo "$*"
}

profile_allowed() {
  local needle="$1"
  [[ ",$STARTABLE_PROFILES," == *",$needle,"* ]]
}

open_url() {
  local url="$1"
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 &
  elif command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1 &
  fi
  echo "$url"
}

print_ports() {
  if command -v ss >/dev/null 2>&1; then
    ss -ltn | awk 'NR==1 || /:5432 |:6379 |:7700 |:1025 |:8025 |:9080 |:8888 |:5672 |:15672 |:3002 |:3003 |:5173 /'
    return
  fi

  if command -v lsof >/dev/null 2>&1; then
    echo "COMMAND PID USER FD TYPE DEVICE SIZE/OFF NODE NAME"
    lsof -nP -iTCP -sTCP:LISTEN | awk 'NR==1 || /:(5432|6379|7700|1025|8025|9080|8888|5672|15672|3002|3003|5173)$/'
    return
  fi

  echo "Neither 'ss' nor 'lsof' found; skipping host port inspection."
}

cmd_up() {
  local requested=()
  while [ $# -gt 0 ]; do
    case "$1" in
      --with)
        [ $# -ge 2 ] || { echo "--with requires a value" >&2; exit 1; }
        IFS=',' read -r -a extra <<<"$2"
        for p in "${extra[@]}"; do
          requested+=("$p")
        done
        shift 2
        ;;
      *)
        echo "Unknown option for up: $1" >&2
        exit 1
        ;;
    esac
  done

  local profiles=("${DEFAULT_PROFILES[@]}")
  for p in "${requested[@]}"; do
    case "$p" in
      '') ;;
      *)
        if ! profile_allowed "$p"; then
          echo "Unknown profile: $p (allowed: $STARTABLE_PROFILES)" >&2
          exit 1
        fi
        # shellcheck disable=SC2076  # literal substring match is intended
        if [[ ! " ${profiles[*]} " =~ " ${p} " ]]; then
          profiles+=("$p")
        fi
        ;;
    esac
  done

  ensure_network
  local profile_csv
  profile_csv="$(join_profiles "${profiles[@]}")"
  COMPOSE_PROFILES="$profile_csv" dc up -d
  echo "Running profiles: $profile_csv"
}

cmd_down() {
  COMPOSE_PROFILES="$ALL_PROFILES" dc down
}

cmd_restart() {
  cmd_down
  cmd_up "$@"
}

cmd_ps() {
  COMPOSE_PROFILES="$ALL_PROFILES" dc ps
}

cmd_logs() {
  if [ $# -gt 0 ]; then
    COMPOSE_PROFILES="$ALL_PROFILES" dc logs -f "$1"
  else
    COMPOSE_PROFILES="$ALL_PROFILES" dc logs -f
  fi
}

cmd_open() {
  local target="${1:-}"
  case "$target" in
    mailpit) open_url "http://localhost:8025" ;;
    adminer) open_url "http://localhost:9080" ;;
    dozzle) open_url "http://localhost:8888" ;;
    rabbitmq) open_url "http://localhost:15672" ;;
    meili|meilisearch) open_url "http://localhost:7700" ;;
    *)
      echo "Usage: devhub open [mailpit|adminer|dozzle|rabbitmq|meili]" >&2
      exit 1
      ;;
  esac
}

cmd_db() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    create)
      ensure_network
      COMPOSE_PROFILES="core" dc up -d postgres >/dev/null
      "$SCRIPTS_DIR/create-project-db.sh" "$@"
      ;;
    import)
      local importer="${DEVHUB_IMPORT_SCRIPT:-$SCRIPTS_DIR/import-db.sh}"
      [ -x "$importer" ] || { echo "DB importer not found or not executable: $importer" >&2; echo "Place a custom script at $SCRIPTS_DIR/import-db.sh or set DEVHUB_IMPORT_SCRIPT." >&2; exit 1; }
      ensure_network
      COMPOSE_PROFILES="core" dc up -d mysql >/dev/null
      "$importer" "${1:-all}"
      ;;
    list)
      local pg_user
      pg_user=$(awk -F= '$1=="POSTGRES_USER"{print $2}' "$ENV_FILE" | tail -n1)
      pg_user="${pg_user:-test}"
      docker exec "$POSTGRES_CONTAINER" psql -U "$pg_user" -d postgres -Atc "SELECT datname FROM pg_database WHERE datistemplate=false ORDER BY datname;"
      ;;
    *)
      echo "Usage: devhub db [create <db_name> [db_user] [db_password]|import [trading|distribution|all]|list]" >&2
      exit 1
      ;;
  esac
}

cmd_doctor() {
  ensure_network
  echo "DevHub directory: $DEVHUB_DIR"
  echo "Compose file: $COMPOSE_FILE"
  echo "Network: $NETWORK_NAME"
  echo ""
  echo "Docker network status:"
  docker network inspect "$NETWORK_NAME" --format '{{.Name}} (driver={{.Driver}})'
  echo ""
  echo "Container health summary:"
  "$SCRIPTS_DIR/healthcheck.sh"
  echo ""
  echo "Host ports:"
  print_ports
}

resolve_override() {
  local project="$1"
  local override_file="$DEVHUB_DIR/overrides/${project}-app.override.yml"

  if [ ! -f "$override_file" ]; then
    echo "No override found: ${project}-app.override.yml" >&2
    echo "" >&2
    echo "Available projects:" >&2
    for f in "$DEVHUB_DIR/overrides/"*-app.override.yml; do
      [ -f "$f" ] || continue
      local name
      name=$(basename "$f" | sed 's/-app\.override\.yml$//')
      echo "  $name" >&2
    done
    return 1
  fi

  echo "$override_file"
}

resolve_profiles() {
  local override_file="$1"
  local svc_names
  svc_names=$(resolve_override_services "$override_file")

  local svc_filter
  svc_filter=$(printf '%s' "$svc_names" | tr ' ' '\n' | jq -R . | jq -s 'map(select(length>0))')

  local profiles
  profiles=$(COMPOSE_PROFILES="$ALL_PROFILES" dc -f "$override_file" config --format json 2>/dev/null \
    | jq -r --argjson svcs "$svc_filter" '
      .services as $all |
      ($svcs | map(. as $s | $all[$s] // empty |
        ((.profiles // []) + ([.depends_on // {} | keys[] | . as $d | $all[$d] // empty | .profiles // [] | .[]] ))
      ) | flatten | unique | join(","))
    ')
  echo "${profiles:-}"
}

cmd_runtime() {
  local project="${1:-}"
  [ -n "$project" ] || { resolve_override ""; return 1; }

  local override_file
  override_file=$(resolve_override "$project") || exit 1

  ensure_network

  local profiles
  profiles=$(resolve_profiles "$override_file")

  COMPOSE_PROFILES="$profiles" dc -f "$override_file" up -d
  echo "Started $project runtime (profiles: $profiles)"
  echo ""
  COMPOSE_PROFILES="$profiles" dc -f "$override_file" ps
}

resolve_override_services() {
  local override_file="$1"
  awk '/^services:/{found=1; next} found && /^  [^ ]/ && /:/{gsub(/:.*/, ""); gsub(/^  /, ""); printf "%s ", $0} /^[^ ]/ && !/^services:/{found=0}' "$override_file" | sed 's/ $//'
}

cmd_runtime_down() {
  local project="${1:-}"
  [ -n "$project" ] || { echo "Usage: devhub down-runtime <project>" >&2; exit 1; }

  local override_file
  override_file=$(resolve_override "$project") || exit 1

  local services
  services=$(resolve_override_services "$override_file")

  local profiles
  profiles=$(resolve_profiles "$override_file")

  # Only stop/rm project-specific services, not shared infra
  # shellcheck disable=SC2086
  COMPOSE_PROFILES="$profiles" dc -f "$override_file" stop $services
  COMPOSE_PROFILES="$profiles" dc -f "$override_file" rm -f $services
  echo "Stopped $project runtime ($services)"
}

cmd_project() {
  "$PROJECT_SCRIPT" "$@"
}

cmd_wt() {
  local sub="${1:-}"
  shift || true
  case "$sub" in
    add) "$WT_ADD_SCRIPT" "$@" ;;
    list) "$WT_LIST_SCRIPT" "$@" ;;
    status) "$WT_STATUS_SCRIPT" "$@" ;;
    rm|remove) "$WT_RM_SCRIPT" "$@" ;;
    *)
      cat >&2 <<'EOF'
Usage: devhub wt <command> [args]

Commands:
  add <project> <branch> [base-ref] [--json]   Create/register a worktree (exit 3 if already registered)
  list <project> [--json]                      List registered worktrees
  status <project> [slug] [--json]             Show http/db/runtime state per worktree
  rm <project> <slug> [--json] [--force]        Remove a worktree (exit 5 if dirty)
EOF
      exit 1
      ;;
  esac
}

cmd_help() {
  cat <<'EOF'
Usage: devhub <command> [options]

Commands:
  up [--with profile[,profile]]        Start shared services (default: core)
  down                                Stop/remove shared services
  restart                             Restart shared services (core)
  ps                                  Show service status
  logs [service]                      Follow logs
  open <target>                       Open service URL
  db create <db> [user] [password]    Create project database/user
  db import [args]                     Run custom DB import script (see DEVHUB_IMPORT_SCRIPT)
  db list                             List non-template databases
  project init <name> --stack <stack> Register a worktree-enabled project
  project adopt <path>                One-shot adoption of an existing Git checkout
  project list                        List registered projects
  project show <name>                 Show a project registry file
  wt add <project> <branch> [base]    Create/register a project worktree
  wt list <project>                   List project worktrees
  wt status <project> [slug]          Show worktree http/db/runtime status
  wt rm <project> <slug> [--force]    Remove a project worktree
  doctor                              Show health and networking diagnostics
  runtime <project>                   Start project runtime (auto-detected from overrides/)
  down-runtime <project>             Stop project runtime
  version                             Show the installed DevHub version
  help                                Show this help

Profiles:
  core, async, node

Stacks:
  symfony, laravel, nextjs, tanstack-start, hono, fastapi-ddd

Projects:
  Add local override files as overrides/<name>-app.override.yml.

Machine output:
  wt add/list/status/rm and project list accept --json (stable schema, "v":1).
  Exit codes: wt add 3 = already registered, 4 = no free port; wt rm 5 = dirty worktree.
EOF
}

cmd_version() {
  if [ -f "$VERSION_FILE" ]; then
    tr -d '[:space:]' < "$VERSION_FILE"
    echo
  else
    echo "unknown"
  fi
}

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    help|-h|--help)
      cmd_help
      exit 0
      ;;
    version|--version|-v)
      cmd_version
      exit 0
      ;;
    up|down|restart|ps|logs|open|db|doctor|runtime|down-runtime|project|wt) ;;
    *)
      echo "Unknown command: $cmd" >&2
      cmd_help
      exit 1
      ;;
  esac

  case "$cmd" in
    project)
      require_cmd git
      ;;
    wt)
      require_cmd git
      ;;
    *)
      require_cmd docker
      case "$cmd" in runtime|down-runtime) require_cmd jq ;; esac
      ensure_files
      ;;
  esac

  case "$cmd" in
    up) cmd_up "$@" ;;
    down) cmd_down ;;
    restart) cmd_restart "$@" ;;
    ps) cmd_ps ;;
    logs) cmd_logs "$@" ;;
    open) cmd_open "$@" ;;
    db) cmd_db "$@" ;;
    doctor) cmd_doctor ;;
    runtime) cmd_runtime "$@" ;;
    down-runtime) cmd_runtime_down "$@" ;;
    project) cmd_project "$@" ;;
    wt) cmd_wt "$@" ;;
  esac
}

main "$@"
